{
  "name": "cheaterboy",
  "version": "1.0.0",
  "description": "cheaterBoy with visible overlay",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:start": "electron . --dev",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-speech-recognition": "^4.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "regenerator-runtime": "^0.14.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "electron": "^25.3.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "vite": "^4.4.5"
  },
  "build": {
    "appId": "com.cheaterboy.app",
    "productName": "cheaterBoy",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "main.js",
      "capture.html",
      "package.json"
    ]
  }
}
